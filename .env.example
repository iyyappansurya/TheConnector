# Provider: "meta" for Meta Cloud API, "gupshup" for Gupshup BSP
WA_PROVIDER=meta

# Meta Cloud API
WHATSAPP_TOKEN=            # Access token from Meta App Dashboard (use System User permanent token)
WHATSAPP_PHONE_NUMBER_ID=  # Phone Number ID from Meta App Dashboard
WHATSAPP_VERIFY_TOKEN=     # Verify token you set for webhook verification
WHATSAPP_APP_SECRET=       # App Secret from Meta App Dashboard → App Settings → Basic (for webhook signature verification)

# Gupshup (legacy, only if WA_PROVIDER=gupshup)
# GUPSHUP_API_KEY=
# GUPSHUP_SOURCE_NUMBER=
# GUPSHUP_APP_NAME=

# Roles
DOCTOR_WA_NUMBER=          # Doctor's WhatsApp number with country code, e.g. 919XXXXXXXXX
PHARMACY_WA_NUMBER=        # Pharmacy's WhatsApp number with country code
PHARMACY_NAME=             # e.g. "MedPlus Anna Nagar"
DOCTOR_NAME=               # e.g. "Dr. K. Mehta"
DOCTOR_REG_NUMBER=         # e.g. "MCI-XXXXX"
PORT=3000
REDIS_URL=redis://localhost:6379

# --- E2E Testing ---
TEST_PATIENT_NUMBER=       # Patient's test number, e.g. 918610447907
WEBHOOK_URL=               # Remote webhook URL for e2e tests, e.g. https://yourdomain.com/webhook
